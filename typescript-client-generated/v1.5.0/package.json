{
  "name": "@tmiclient/client",
  "version": "1.5.0",
  "description": "TypeScript client for TMI (Threat Modeling Improved) API",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0",
    "eslint": "^10.0",
    "typescript": "^6.0",
    "typescript-eslint": "^8.60",
    "vitest": "^4.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ericfitz/tmi-clients.git"
  },
  "keywords": [
    "tmi",
    "threat-modeling",
    "api-client",
    "openapi",
    "typescript"
  ]
}
